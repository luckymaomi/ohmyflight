    "test:smoke": "tsx scripts/build.mts && vitest run tests/smoke",
    "test:tool": "tsx scripts/build.mts && vitest run tests/tool"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "xlsx-js-style": "^1.2.0"
  }
}
